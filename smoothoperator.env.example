# SmoothOperator Secrets (passwords only)
# Copy to one of the following (first found wins if env var is not set):
#   .env                  (preferred — also used by many tools)
#   smoothoperator.env
# Never commit the real file. File permissions should be 600 (owner read/write).
#
# Existing environment variables ALWAYS take precedence over this file.
#
# Required: RabbitMQ password, minimum 16 characters.
RABBITMQ_PASS=__REQUIRED_CHANGE_ME_MIN_16_CHARS__
