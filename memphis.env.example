# Memphis Configuration Example
# Copy to memphis.env and customize

# RabbitMQ
# REQUIRED: Set strong, unique credentials before running
RABBITMQ_HOST=localhost
RABBITMQ_PORT=5672
RABBITMQ_USER=__REQUIRED_CHANGE_ME__
RABBITMQ_PASS=__REQUIRED_CHANGE_ME_MIN_16_CHARS__
RABBITMQ_VHOST=/

# Liquidsoap
# Transport: 'telnet' (TCP, default) or 'socket' (Unix domain socket)
LIQUIDSOAP_PROTOCOL=telnet

# For telnet transport (required when LIQUIDSOAP_PROTOCOL=telnet)
LIQUIDSOAP_HOST=127.0.0.1
LIQUIDSOAP_PORT=1234

# For socket transport (required when LIQUIDSOAP_PROTOCOL=socket)
# LIQUIDSOAP_SOCKET_PATH=/var/run/liquidsoap/ls.sock

# Common settings
LIQUIDSOAP_TIMEOUT_MS=3000
LIQUIDSOAP_RECONNECT_MAX_DELAY_MS=30000

# HTTP Health Check
HTTP_HEALTHCHECK_PORT=9000

# Logging
LOG_LEVEL=INFO
LOG_FILE=/var/log/memphis.log
